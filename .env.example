# ============================================================
#  KGP Crew Monitoring System — Environment Variables
#  Copy this file to .env and fill in real values before deploy
# ============================================================

# --- Flask / Security ---
# REQUIRED in production — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_32_CHAR_HEX

# Shared secret between webapp and scraper — MUST match in both
API_SECRET=cms-sync-secret-key-2026

# Set to "production" to enable HTTPS-only cookies and disable Flask debug
FLASK_ENV=production

# --- Database ---
# Absolute path to SQLite file. Default: <project_root>/data/crew.db
DB_PATH=/home/ubuntu/cms/data/crew.db

# --- Network ---
# Port gunicorn listens on (nginx proxies from 80 to this port)
PORT=8080

# --- Google Vision API (for CAPTCHA solving) ---
# Path to your GCP service account JSON credentials file
GOOGLE_APPLICATION_CREDENTIALS=/home/ubuntu/cms/scraper/algebraic-cycle-432817-r8-ae9fa17cac37.json

# Alternative: base64-encode the JSON and set here (useful for Docker/CI)
# GCP_CREDENTIALS_B64=<base64-encoded-json>

# --- CMS Credentials (override DB values for scripted deploys) ---
# CMS_USERNAME=your_cms_username
# CMS_PASSWORD=your_cms_password
